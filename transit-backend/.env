# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — .env is in .gitignore.

# Active AI provider: groq | openai | gemini
# If the active provider hits its daily rate limit, the app automatically
# falls back to the next provider that has an API key configured below.
AI_PROVIDER=groq

# ── Groq (free tier — recommended for dev) ───────────────────────────────────
# Get key at https://console.groq.com
GROQ_API_KEY=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
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── Gemini (free tier — good fallback for dev) ────────────────────────────────
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyA0Z10i5hzMtxqtwBk2eqbTdz7NEr6ME44
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (production) ───────────────────────────────────────────────────────
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Durham Region Transit GTFS-RT feed URLs
# From: https://opendata.durham.ca/search?tags=Durham%2520Transit
# IMPORTANT: Use the direct download/feed URL, NOT the /explore page URL.
# The correct URL returns raw protobuf binary (.pb), not an HTML page.
GTFS_RT_TRIP_UPDATES_URL=https://drtonline.durhamregiontransit.com/gtfsrealtime/TripUpdates
GTFS_RT_VEHICLE_POSITIONS_URL=https://drtonline.durhamregiontransit.com/gtfsrealtime/VehiclePositions
GTFS_RT_ALERTS_URL=https://drtonline.durhamregiontransit.com/gtfsrealtime/ServiceAlerts

# Set to true once Durham Region publishes a working Service Alerts feed URL.
# When false the poller skips alerts entirely (no error noise) and the /alerts
# endpoint returns an empty list with available=false.
SERVICE_ALERTS_ENABLED=false

# SQLite database path (relative to transit-backend/)
DB_PATH=data/transit.db

# How often the RT poller fetches new data (seconds)
POLL_INTERVAL_SECONDS=30

# How many hours of RT data to keep in the database
RT_RETENTION_HOURS=2


# ── Gmail SMTP (for password reset emails) ────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: Google Account → Security → App Passwords
# 3. Create an App Password for "Mail / Other (DRT Assistant)"
# 4. Paste the 16-character app password into SMTP_PASSWORD below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=shiva.bhalla@gmail.com
SMTP_PASSWORD=uuih xojp gapw umhl
SMTP_FROM=shiva.bhalla@gmail.com
# How long a reset link stays valid (hours). Default: 1
RESET_TOKEN_EXPIRE_HOURS=1
# Minimum gap before re-sending a reset email (minutes). Blocks spamming.
RESET_RESEND_COOLDOWN_MINUTES=5


